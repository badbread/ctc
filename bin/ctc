#!/usr/bin/env bash
# ctc — Claude Terminal Connect. A phone-friendly TUI that launches Claude Code
# as detached, Remote-Control-enabled backends in tmux, then lets you manage
# them. You drive the actual coding from the Claude mobile/web app; ctc is the
# launcher/manager you reach over SSH (e.g. from Termux on Android).
#
#   ctc            -> session manager (running sessions, launch new, options)
#   ctc <name>     -> fuzzy-jump: launch/connect the project matching <name>
#   ctc <path>     -> launch in an explicit directory
#
# Config: ~/.config/ctc/config (see ctc.config.example). Env vars override file.
# Project: https://github.com/badbread/ctc   License: MIT
set -euo pipefail

# --- Resolve config dir (XDG-friendly) -------------------------------------
CTC_CONFIG_DIR="${CTC_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/ctc}"
CTC_STATE_DIR="${CTC_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/ctc}"
mkdir -p "$CTC_CONFIG_DIR" "$CTC_STATE_DIR" 2>/dev/null || true

# Defaults (overridable by the config file, then by env vars). BASE starts empty
# so we can tell "never configured" apart from a real choice and run first-run
# detection / prompt. resolve_base() fills it in after load_cfg.
BASE=""                                  # where project dirs live (resolved below)
CLAUDE_BIN="$(command -v claude || echo claude)"
TMUX_BIN="$(command -v tmux || echo tmux)"

HISTFILE="$CTC_STATE_DIR/history"        # most-recent-first list of launched dirs
CFGFILE="$CTC_CONFIG_DIR/config"         # persisted launch options + BASE

# ---------------------------------------------------------------------------
# Launch options (persisted in $CFGFILE). These mirror the real `claude` flags
# so you launch sessions the same way the Claude app would.
#   MODE     = claude --permission-mode: auto acceptEdits bypassPermissions
#              default dontAsk plan
#   MODEL    = claude --model: default(none) opus sonnet haiku
#   RC       = on | off                 (--remote-control)
#   CONTINUE = on | off                 (--continue: resume the dir's last convo)
#   LAUNCH   = detached | attach        (ctc: backend-for-app vs open-in-terminal)
# ---------------------------------------------------------------------------
# Default MODE is acceptEdits, not auto: a detached backend reachable from your
# phone shouldn't run arbitrary commands with nobody watching. acceptEdits
# auto-applies file edits but still gates command execution. Opt into auto in
# the config or the options screen once you understand the tradeoff.
MODE="acceptEdits"
MODEL="default"
RC="on"
CONTINUE="off"
LAUNCH="detached"
DEPTH="2"            # how many levels under BASE to scan for git repos (1 = flat)
VALID_MODES="auto acceptEdits bypassPermissions default dontAsk plan"
VALID_MODELS="default opus sonnet haiku"

load_cfg() {
  # Read only the keys we own; ignore anything else for safety.
  if [ -f "$CFGFILE" ]; then
    local k v
    while IFS='=' read -r k v; do
      v="${v#\"}"; v="${v%\"}"        # strip surrounding quotes
      case "$k" in
        BASE)     [ -n "$v" ] && BASE="${v/#\~/$HOME}" ;;
        MODE)     case " $VALID_MODES "  in *" $v "*) MODE="$v";;  esac ;;
        MODEL)    case " $VALID_MODELS " in *" $v "*) MODEL="$v";; esac ;;
        RC)       case "$v" in on|off) RC="$v";; esac ;;
        CONTINUE) case "$v" in on|off) CONTINUE="$v";; esac ;;
        LAUNCH)   case "$v" in detached|attach) LAUNCH="$v";; esac ;;
        DEPTH)    case "$v" in ''|*[!0-9]*) ;; *) DEPTH="$v";; esac ;;
      esac
    done < "$CFGFILE"
  fi
  [ -n "${CTC_BASE:-}" ] && BASE="${CTC_BASE/#\~/$HOME}"   # env wins
  return 0   # don't let a false test above leak non-zero into set -e
}

# Persist options. Preserves BASE (set on first run / via config).
save_cfg() {
  local tmp; tmp="$(mktemp)"
  printf 'BASE=%s\nMODE=%s\nMODEL=%s\nRC=%s\nCONTINUE=%s\nLAUNCH=%s\nDEPTH=%s\n' \
    "$BASE" "$MODE" "$MODEL" "$RC" "$CONTINUE" "$LAUNCH" "$DEPTH" > "$tmp"
  mv "$tmp" "$CFGFILE"
}

# Decide where projects live. Order: configured BASE (if it exists) → autodetect
# a common dir → first-run prompt → fall back to $HOME. Saves the choice.
resolve_base() {
  # 1) already configured and real
  if [ -n "$BASE" ] && [ -d "$BASE" ]; then return 0; fi
  # 2) autodetect common project roots
  local d
  for d in "$HOME/projects" "$HOME/code" "$HOME/src" "$HOME/dev" "$HOME/git" "$HOME/repos" "$HOME/workspace"; do
    if [ -d "$d" ]; then BASE="$d"; save_cfg; return 0; fi
  done
  # 3) first-run prompt (only if interactive). Otherwise fall back to $HOME.
  if have_tty; then
    banner 2>/dev/null || true
    printf '\n %sFirst run — where do your projects live?%s\n' "$BOLD" "$RST"
    printf ' %s(directory that contains your project folders / git repos)%s\n\n' "$DIM" "$RST"
    local default="$HOME/projects" ans
    printf ' %spath%s [%s%s%s]: ' "$ORG" "$RST" "$C2" "$default" "$RST"
    read -r ans
    ans="${ans:-$default}"; ans="${ans/#\~/$HOME}"
    [ -d "$ans" ] || mkdir -p "$ans" 2>/dev/null || true
    BASE="$ans"; save_cfg
    printf ' %ssaved%s %s → %s%s\n' "$GRN" "$RST" "$CFGFILE" "$C2" "$BASE"; sleep 1
  else
    BASE="$HOME"
  fi
  return 0
}

# Build the claude argument array from current options into global CLAUDE_ARGS.
build_claude_args() {
  CLAUDE_ARGS=()
  case "$MODE" in
    default) ;;  # no flag — claude's own default
    *) CLAUDE_ARGS+=(--permission-mode "$MODE") ;;
  esac
  [ "$MODEL" != "default" ] && CLAUDE_ARGS+=(--model "$MODEL")
  [ "$CONTINUE" = "on" ]    && CLAUDE_ARGS+=(--continue)
  [ "$RC" = "on" ]          && CLAUDE_ARGS+=(--remote-control)
  return 0   # never let a trailing && leak non-zero into set -e
}

# ---------------------------------------------------------------------------
# Look & feel. Colors only when stdout is a TTY and NO_COLOR is unset.
# 256-color theme with a graceful fall-back to plain text when piped.
# ---------------------------------------------------------------------------
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  E=$'\033'
  RST="${E}[0m";  BOLD="${E}[1m";  DIM="${E}[2m"
  # cyber palette (256-color)
  C1="${E}[38;5;51m"    # bright cyan
  C2="${E}[38;5;45m"    # cyan
  C3="${E}[38;5;39m"    # blue-cyan
  MAG="${E}[38;5;201m"  # hot magenta
  GRN="${E}[38;5;46m"   # neon green
  YEL="${E}[38;5;226m"  # yellow
  ORG="${E}[38;5;208m"  # orange
  GRY="${E}[38;5;244m"  # grey
  RED="${E}[38;5;196m"  # red
else
  RST=""; BOLD=""; DIM=""
  C1=""; C2=""; C3=""; MAG=""; GRN=""; YEL=""; ORG=""; GRY=""; RED=""
fi

# Defensive terminal reset. If anything we spawn (claude's TUI, an inner tmux,
# a crashed attach) left mouse tracking enabled, the terminal floods stdin
# with SGR mouse reports (`35;X;YM…`) and bells on each one whenever the user
# moves the mouse. Disabling all the common mouse modes is safe even if they
# weren't on — and going via /dev/tty means we don't pollute redirected stdout.
reset_terminal() {
  # bash prints redirection-failure errors itself, *before* a command-level
  # `2>/dev/null` takes effect; and `[ -w /dev/tty ]` only checks the node's
  # permission bits, not openability (under docker exec -i without -t the node
  # exists but open() returns ENXIO). A brace group with its own stderr
  # redirection catches bash's redirection error too — that's the form that
  # actually stays quiet when there's no controlling terminal.
  { printf '\033[?1000l\033[?1002l\033[?1003l\033[?1006l' > /dev/tty ; } 2>/dev/null
  return 0
}
trap reset_terminal EXIT

# Terminal width (fallback 80), capped so the banner stays sane on huge screens.
term_cols() {
  local c="${COLUMNS:-0}"
  [ "$c" -gt 0 ] 2>/dev/null || c="$(tput cols 2>/dev/null || echo 80)"
  [ "$c" -gt 0 ] 2>/dev/null || c=80
  [ "$c" -gt 100 ] && c=100
  printf '%s' "$c"
}

# A full-width horizontal rule of repeated char $1 in color $2.
rule() {
  local ch="${1:-─}" col="${2:-$C3}" w; w="$(term_cols)"
  printf '%s' "$col"
  local i=0; while [ "$i" -lt "$w" ]; do printf '%s' "$ch"; i=$((i+1)); done
  printf '%s\n' "$RST"
}

die() { printf '%s%s%s\n' "$RED" "$*" "$RST" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Interactive selectors (Claude-style: arrow/j-k to move, Enter to choose).
# Fall back to a plain numbered prompt when stdin isn't a TTY.
# ---------------------------------------------------------------------------
have_tty() { [ -t 0 ] && [ -t 1 ]; }

# Read one logical keypress from the TTY -> emits a token on stdout:
#   up down left right enter space a-z A-Z digits  esc  (or '' on EOF)
read_key() {
  local k rest
  IFS= read -rsn1 k 2>/dev/null || { printf 'eof'; return; }
  case "$k" in
    '')            printf 'enter'; return ;;          # bare CR/LF
    ' ')           printf 'space'; return ;;
    $'\t')         printf 'tab'; return ;;            # plain Tab (phone-friendly Shift+Tab alt)
    $'\033')                                           # ESC — maybe a sequence
      # try to grab the rest of a CSI seq without blocking long
      IFS= read -rsn2 -t 0.01 rest 2>/dev/null || rest=""
      case "$rest" in
        '[A') printf 'up' ;;   '[B') printf 'down' ;;
        '[C') printf 'right';; '[D') printf 'left' ;;
        '[Z') printf 'shifttab' ;;                      # Shift+Tab (CSI Z)
        '')   printf 'esc'  ;;                          # lone ESC
        *)    printf 'esc'  ;;
      esac
      return ;;
    *)             printf '%s' "$k"; return ;;
  esac
}

# Single-select picker.
#   $1 = title (already-colored ok)
#   remaining args = display rows
# Sets global PICK_INDEX (0-based) and returns 0, or returns 1 on cancel.
# render_extra() (if defined) is called after the list for per-screen footers.
pick_one() {
  local title="$1"; shift
  local -a rows=("$@")
  local n=${#rows[@]} cur=0
  [ "$n" -gt 0 ] || return 1

  if ! have_tty; then
    # non-TTY fallback: numbered prompt
    banner; printf ' %s\n\n' "$title"
    local i=1; for r in "${rows[@]}"; do printf '   %s%2d)%s %s\n' "$C3" "$i" "$RST" "$r"; i=$((i+1)); done
    printf '\n %s▶%s select [1]: ' "$MAG" "$RST"
    local c; read -r c; c="${c:-1}"
    case "$c" in ''|*[!0-9]*) return 1 ;; esac
    [ "$c" -ge 1 ] && [ "$c" -le "$n" ] || return 1
    PICK_INDEX=$((c-1)); return 0
  fi

  # optional: PICK_SKIP holds an index the cursor jumps over (e.g. a divider)
  local skip="${PICK_SKIP:-_none_}"
  [ "$cur" = "$skip" ] && cur=$(( (cur+1) % n ))
  # optional: PICK_KEYS = space-separated "letter:index" hotkeys (e.g. "a:0 k:1 b:2").
  # These take precedence over vim j/k, so a screen that registers k/j/q overrides nav.
  local keys="${PICK_KEYS:-}"
  while :; do
    banner; printf ' %s\n' "$title"
    local i=0
    for r in "${rows[@]}"; do
      if [ "$i" -eq "$cur" ]; then
        printf '%s%s ▎%s %s%s%s\n' "$MAG" "$BOLD" "$RST" "$BOLD" "$r" "$RST"
      else
        printf '   %s\n' "$r"
      fi
      i=$((i+1))
    done
    declare -F render_extra >/dev/null 2>&1 && render_extra
    if [ -n "${PICK_SHIFTTAB:-}" ]; then
      printf '%s   ↑↓ move · ⏎ select · ⇧⇥ cycle mode · q quit%s\n' "$DIM" "$RST"
    else
      printf '%s   ↑↓ move · ⏎ select · q back%s\n' "$DIM" "$RST"
    fi
    local key; key="$(read_key)"
    # hotkey match first (screen-registered letters win over nav)
    if [ -n "$keys" ]; then
      local pair found=""
      for pair in $keys; do
        [ "${pair%%:*}" = "$key" ] && { found="${pair##*:}"; break; }
      done
      [ -n "$found" ] && { PICK_INDEX=$found; return 0; }
    fi
    case "$key" in
      up|k)    cur=$(( (cur-1+n) % n )); [ "$cur" = "$skip" ] && cur=$(( (cur-1+n) % n )) ;;
      down|j)  cur=$(( (cur+1) % n )); [ "$cur" = "$skip" ] && cur=$(( (cur+1) % n )) ;;
      shifttab|tab)
        # Claude-style: Shift+Tab cycles permission mode. Opt-in per screen via
        # PICK_SHIFTTAB=<fn>; the fn mutates state, we redraw in place.
        [ -n "${PICK_SHIFTTAB:-}" ] && "$PICK_SHIFTTAB" ;;
      enter)   [ "$cur" = "$skip" ] || { PICK_INDEX=$cur; return 0; } ;;
      q|esc|eof) return 1 ;;
    esac
  done
}

# Multi-select picker (for kill). Space marks, 'a' toggles all, Enter confirms.
#   $1 = title; remaining args = rows
# Sets global PICK_MARKS (array of 0/1, parallel to rows); returns 0 on Enter,
# 1 on cancel.
pick_many() {
  local title="$1"; shift
  local -a rows=("$@")
  local n=${#rows[@]} cur=0 i
  [ "$n" -gt 0 ] || return 1
  PICK_MARKS=(); for ((i=0;i<n;i++)); do PICK_MARKS[i]=0; done

  if ! have_tty; then return 1; fi   # multi-select needs a TTY

  while :; do
    banner; printf ' %s\n\n' "$title"
    for ((i=0;i<n;i++)); do
      local box="[ ]"; [ "${PICK_MARKS[i]}" = "1" ] && box="${RED}[x]${RST}"
      if [ "$i" -eq "$cur" ]; then
        printf '  %s%s ❯%s %s %s%s%s\n' "$MAG" "$BOLD" "$RST" "$box" "$BOLD" "${rows[i]}" "$RST"
      else
        printf '     %s %s%s%s\n' "$box" "$DIM" "${rows[i]}" "$RST"
      fi
    done
    printf '\n %s↑/↓ j/k%s move   %sSpace%s mark   %sa%s all   %sEnter%s confirm   %sq/Esc%s cancel\n' \
      "$GRY" "$RST" "$C2" "$RST" "$C2" "$RST" "$GRN" "$RST" "$ORG" "$RST"
    case "$(read_key)" in
      up|k)    cur=$(( (cur-1+n) % n )) ;;
      down|j)  cur=$(( (cur+1) % n )) ;;
      space)   PICK_MARKS[cur]=$(( 1 - PICK_MARKS[cur] )) ;;
      a|A)
        # if any unmarked -> mark all; else clear all
        local anyoff=0; for ((i=0;i<n;i++)); do [ "${PICK_MARKS[i]}" = "0" ] && anyoff=1; done
        for ((i=0;i<n;i++)); do PICK_MARKS[i]=$anyoff; done ;;
      enter)   return 0 ;;
      q|esc|eof) return 1 ;;
    esac
  done
}

# Rounded-box helpers (Claude-Code-style framing). Width-aware, color $2.
box_w() { local w; w="$(term_cols)"; printf '%s' $((w-2)); }
box_top()    { local w; w="$(box_w)"; printf '%s╭' "${1:-$C3}"; printf '─%.0s' $(seq 1 "$w"); printf '╮%s\n' "$RST"; }
box_bottom() { local w; w="$(box_w)"; printf '%s╰' "${1:-$C3}"; printf '─%.0s' $(seq 1 "$w"); printf '╯%s\n' "$RST"; }
# box_line "<colored text>" <plain-text-len> [bordercolor] — pads to box width.
box_line() {
  local text="$1" len="$2" col="${3:-$C3}" w; w="$(box_w)"
  local pad=$(( w - 1 - len )); [ "$pad" -lt 0 ] && pad=0
  printf '%s│%s %s' "$col" "$RST" "$text"
  printf ' %.0s' $(seq 1 "$pad") 2>/dev/null
  printf '%s│%s\n' "$col" "$RST"
}

# The Claude-Code-style header: rounded box, wordmark + live status line.
banner() {
  clear 2>/dev/null || true
  local host; host="$(hostname)"
  # Build plain + colored versions token-for-token so visible widths match
  # exactly (padding is computed from the plain version's length).
  local l1_plain="ctc · claude terminal connect"
  local l1="${BOLD}${MAG}ctc${RST}${DIM} · claude terminal connect${RST}"
  # status: full = host · model · mode · rc · launch; compact drops host & rc-off
  # when the full line would overflow the (narrow phone) box interior.
  local rcw; [ "$RC" = on ] && rcw="rc:on" || rcw="rc:off"
  local full_plain compact_plain
  full_plain="$(printf '%s · %s · %s · %s · %s' "$host" "$MODEL" "$MODE" "$rcw" "$LAUNCH")"
  compact_plain="$(printf '%s · %s · %s · %s' "$MODEL" "$MODE" "$rcw" "$LAUNCH")"
  local modeltag mtag ltag rtag
  modeltag="$(model_label)"; mtag="$(mode_label)"; ltag="$(launch_short)"
  [ "$RC" = on ] && rtag="${GRN}rc:on${RST}" || rtag="${GRY}rc:off${RST}"
  local interior; interior="$(box_w)"
  local l2 l2_plain
  if [ "${#full_plain}" -le "$((interior-1))" ]; then
    l2_plain="$full_plain"
    l2="$(printf '%s%s%s · %s · %s · %s · %s' "$C2" "$host" "$RST" "$modeltag" "$mtag" "$rtag" "$ltag")"
  else
    l2_plain="$compact_plain"
    l2="$(printf '%s · %s · %s · %s' "$modeltag" "$mtag" "$rtag" "$ltag")"
  fi
  box_top "$C3"
  box_line "$l1" "${#l1_plain}" "$C3"
  box_line "$l2" "${#l2_plain}" "$C3"
  box_bottom "$C3"
}

# tmux session name for a given dir: claude-<basename>, sanitized for tmux.
session_name() {
  local b; b="$(basename "$1")"
  printf 'claude-%s' "$(printf '%s' "$b" | tr -c 'A-Za-z0-9_-' '_')"
}

# Record a launch (dedup, newest first, cap 20).
record_history() {
  local dir="$1" tmp
  tmp="$(mktemp)"
  { printf '%s\n' "$dir"; [ -f "$HISTFILE" ] && grep -vxF "$dir" "$HISTFILE" || true; } \
    | grep -vE '^$' | head -20 > "$tmp"
  mv "$tmp" "$HISTFILE"
}

# Claude stores per-project trust in ~/.claude.json under
# projects["<abs-dir>"].hasTrustDialogAccepted. A detached backend gets a real
# pty from tmux, so claude shows its "do you trust this folder?" dialog and
# blocks — with nobody attached, the Remote Control session never registers.
# We resolve that *before* launch by pre-trusting the dir, but only after the
# user okays it in ctc's own prompt (the real dialog is unreachable here).
CLAUDE_JSON="${CLAUDE_CONFIG_DIR:-$HOME}/.claude.json"

# 0 if claude already trusts $1; non-zero otherwise (incl. no config yet).
project_trusted() {
  [ -f "$CLAUDE_JSON" ] || return 1
  command -v python3 >/dev/null 2>&1 || return 1
  python3 - "$CLAUDE_JSON" "$1" <<'PY'
import json, sys
cfg, d = sys.argv[1], sys.argv[2]
try:
    p = json.load(open(cfg)).get("projects", {}).get(d, {})
except Exception:
    sys.exit(1)
sys.exit(0 if p.get("hasTrustDialogAccepted") else 1)
PY
}

# Mark $1 as trusted in ~/.claude.json (create/merge in place). Returns non-zero
# if we can't safely edit it — caller then falls back to manual attach-and-accept.
trust_project() {
  command -v python3 >/dev/null 2>&1 || return 1
  python3 - "$CLAUDE_JSON" "$1" <<'PY'
import json, os, sys, tempfile
cfg, d = sys.argv[1], sys.argv[2]
try:
    data = json.load(open(cfg)) if os.path.exists(cfg) else {}
    if not isinstance(data, dict):
        sys.exit(1)
except Exception:
    sys.exit(1)
proj = data.setdefault("projects", {})
proj.setdefault(d, {})["hasTrustDialogAccepted"] = True
fd, tmp = tempfile.mkstemp(dir=os.path.dirname(cfg) or ".")
try:
    with os.fdopen(fd, "w") as f:
        json.dump(data, f, indent=2)
    os.replace(tmp, cfg)
except Exception:
    try: os.unlink(tmp)
    except OSError: pass
    sys.exit(1)
PY
}

# Ensure a detached tmux session running claude exists for $1 (abs dir).
# Creates it if missing. Echoes nothing; returns 0. Does NOT attach.
ensure_session() {
  local dir="$1" sess; sess="$(session_name "$dir")"
  if ! "$TMUX_BIN" has-session -t "$sess" 2>/dev/null; then
    build_claude_args
    "$TMUX_BIN" new-session -d -s "$sess" -c "$dir" "$CLAUDE_BIN" "${CLAUDE_ARGS[@]}"
  fi
}

# Launch Claude for $1 (abs, existing dir). Honors $LAUNCH:
#   detached -> start a backend RC session (or reuse), return to menu (no attach)
#   attach   -> start if needed, then attach this terminal (exec)
launch() {
  local dir="$1"
  [ -d "$dir" ] || die "Not a directory: $dir"
  dir="$(cd "$dir" && pwd)"               # canonicalize
  record_history "$dir"

  # Pre-empt claude's trust dialog: a detached backend can't answer it, so the
  # RC session would hang until you attach. Ask here instead, once per project.
  if ! project_trusted "$dir"; then
    printf '\n %s⚠ first launch%s  %s%s%s\n' "$YEL" "$RST" "$BOLD" "$dir" "$RST"
    printf ' %sClaude shows a "trust this folder?" prompt the detached backend%s\n' "$GRY" "$RST"
    printf ' %scan'\''t answer. Trust it now so launches work without attaching?%s [y/N]: ' "$GRY" "$RST"
    local yn; read -r yn
    case "$yn" in
      y|Y)
        if trust_project "$dir"; then
          printf ' %s✓ trusted%s\n' "$GRN" "$RST"
        else
          printf ' %scould not edit %s%s\n' "$YEL" "$CLAUDE_JSON" "$RST"
          printf ' %sattach once (LAUNCH=attach) and accept the dialog manually.%s\n' "$GRY" "$RST"
        fi ;;
      *)
        printf ' %snot trusted — attach once and accept the dialog to connect.%s\n' "$GRY" "$RST" ;;
    esac
  fi

  local sess; sess="$(session_name "$dir")"
  local existed=0
  "$TMUX_BIN" has-session -t "$sess" 2>/dev/null && existed=1

  if [ "$LAUNCH" = "attach" ]; then
    ensure_session "$dir"
    if [ "$existed" = 1 ]; then
      printf '\n %s↻ REATTACH%s  %s%s%s  %s(%s)%s\n' "$GRN" "$RST" "$BOLD" "$sess" "$RST" "$GRY" "$dir" "$RST"
    else
      build_claude_args
      printf '\n %s＋ NEW%s  %s%s%s  %sclaude %s%s\n' "$C1" "$RST" "$BOLD" "$sess" "$RST" "$DIM" "${CLAUDE_ARGS[*]}" "$RST"
    fi
    if [ -n "${TMUX:-}" ]; then
      # Already inside a tmux client. attach-session would either be refused
      # as nested or stack a second client on top of the first, which on some
      # terminals leaves mouse-tracking half-enabled and floods the screen
      # with `35;X;YM` reports on cursor motion. switch-client is the proper
      # nested idiom: retarget THIS client to the inner session.
      printf ' %s%s↪ switching outer tmux to%s %s%s%s\n' \
        "$YEL" "$BOLD" "$RST" "$BOLD" "$sess" "$RST"
      printf ' %sCtrl-b L returns here · Ctrl-b s for session picker%s\n' "$GRY" "$RST"
      sleep 1
      "$TMUX_BIN" switch-client -t "$sess" || \
        printf '\n %sswitch-client failed (different tmux server?). Detach (Ctrl-b d) and rerun ctc.%s\n' \
          "$RED" "$RST"
      return 0
    fi
    # 2s reminder: detach cleanly (keeps it running) vs /exit (ends it)
    printf ' %s%s⎚ Ctrl-b then d%s %sto detach (keeps it running) · %s/exit%s ends it%s\n' \
      "$YEL" "$BOLD" "$RST" "$GRY" "$C2" "$GRY" "$RST"
    sleep 2
    # No exec: keep ctc alive underneath tmux so detaching returns to the menu.
    # Tolerate non-zero (e.g. the session ended via /exit while attached) so
    # set -e doesn't kill ctc — we want to fall back to the menu either way.
    "$TMUX_BIN" attach-session -t "$sess" || true
    return 0
  fi

  # detached (backend) mode — launch and come back to the menu
  ensure_session "$dir"
  build_claude_args
  if [ "$existed" = 1 ]; then
    printf '\n %s● already running%s  %s%s%s\n' "$GRN" "$RST" "$BOLD" "$sess" "$RST"
  else
    printf '\n %s▸ launched%s  %s%s%s  %s(claude %s)%s\n' "$GRN" "$RST" "$BOLD" "$sess" "$RST" "$DIM" "${CLAUDE_ARGS[*]}" "$RST"
  fi
  [ "$RC" = "on" ] && printf ' %sconnect from the Claude app · session: %s%s%s\n' "$GRY" "$C2" "$sess" "$RST"
  sleep 1
  return 0
}

# Git repos under BASE, up to $DEPTH levels deep (1 = flat). Finds .git markers
# and prints their parent dir. Prunes the usual noise so a deep scan stays fast
# and doesn't wander into dependency trees.
list_repos() {
  [ -d "$BASE" ] || return 0
  # .git sits one level below the repo, so search depth is DEPTH+1.
  local md=$((DEPTH + 1))
  # Prune dependency trees and NAS/OS junk (Synology #recycle / @eaDir, trashes,
  # and other dotdirs — but NOT .git, which is what we're looking for) so a deep
  # scan stays fast and the menu doesn't fill with deleted/backup copies.
  find "$BASE" -mindepth 1 -maxdepth "$md" \
       \( -name node_modules -o -name vendor -o -name .cache -o -name .venv \
          -o -name '#recycle' -o -name '@eaDir' -o -name '.Trash*' \
          -o \( -name '.*' ! -name '.git' \) \) -prune -o \
       -name .git -print 2>/dev/null \
    | sed 's#/\.git$##' \
    | sort -u
}

# Build the ordered candidate list: live tmux sessions' dirs + history + repos.
resolve_arg() {
  # $1 is a user token (e.g. "infra"). Match against repo basenames.
  local tok="$1" match
  match="$(list_repos | awk -F/ -v t="$tok" 'tolower($NF) ~ tolower(t){print; c++} END{exit c!=1}')" \
    && { printf '%s\n' "$match"; return 0; }
  # not exactly one match: if it's a real path, accept it
  if [ -d "$tok" ]; then printf '%s\n' "$tok"; return 0; fi
  return 1
}

# Human-readable one-liner of the current launch options, for the status bar.
mode_label() {
  case "$MODE" in
    auto)              printf '%sauto%s'        "$GRN" "$RST" ;;
    acceptEdits)       printf '%sacceptEdits%s' "$C2"  "$RST" ;;
    bypassPermissions) printf '%sBYPASS!%s'     "$RED" "$RST" ;;
    dontAsk)           printf '%sdontAsk%s'     "$ORG" "$RST" ;;
    plan)              printf '%splan%s'        "$YEL" "$RST" ;;
    default)           printf '%sdefault%s'     "$GRY" "$RST" ;;
  esac
}
rc_label() {
  # Plain on/off — matches the other OPTIONS rows' simple-value style
  # (detached, auto, default). RC●/RC○ read as a cryptic status code next to
  # the "remote control" row label.
  if [ "$RC" = "on" ]; then printf '%son%s' "$GRN" "$RST"
  else printf '%soff%s' "$GRY" "$RST"; fi
}
model_label() {
  case "$MODEL" in
    default) printf '%sdefault%s' "$GRY" "$RST" ;;
    *)       printf '%s%s%s' "$C2" "$MODEL" "$RST" ;;
  esac
}
launch_short() {
  if [ "$LAUNCH" = "detached" ]; then printf '%sdetached%s' "$C2" "$RST"
  else printf '%sattach%s' "$GRN" "$RST"; fi
}
continue_label() {
  if [ "$CONTINUE" = "on" ]; then printf '%son%s' "$GRN" "$RST"
  else printf '%soff%s' "$GRY" "$RST"; fi
}
# Shift+Tab handler: cycle permission mode in VALID_MODES order, persist, redraw.
cycle_mode() {
  case "$MODE" in
    auto) MODE=acceptEdits ;; acceptEdits) MODE=bypassPermissions ;;
    bypassPermissions) MODE=default ;; default) MODE=dontAsk ;;
    dontAsk) MODE=plan ;; *) MODE=auto ;;
  esac
  save_cfg
}

# Footer used by options_screen's pick_one: shows the resulting launch line.
render_options_footer() {
  build_claude_args
  printf '\n   %sresulting launch:%s %sclaude %s%s\n' "$GRY" "$RST" "$DIM" "${CLAUDE_ARGS[*]}" "$RST"
  [ "$MODE" = "bypassPermissions" ] && \
    printf '   %s⚠ bypass approves EVERYTHING, including destructive ops%s\n' "$RED" "$RST"
  return 0
}

# Sub-picker: choose the permission mode (maps to claude --permission-mode).
choose_mode() {
  local -a labels=(
    "auto                ${DIM}autonomous, auto-approves safe actions${RST}"
    "acceptEdits         ${DIM}auto-accept file edits, ask before commands${RST}"
    "bypassPermissions   ${RED}approve EVERYTHING incl. destructive ops${RST}"
    "default             ${DIM}claude's own default behavior${RST}"
    "dontAsk             ${DIM}don't prompt for permissions${RST}"
    "plan                ${DIM}plan first, don't act${RST}"
  )
  local -a vals=(auto acceptEdits bypassPermissions default dontAsk plan)
  pick_one "${BOLD}${C3} PERMISSION MODE ${RST} ${GRY}(claude --permission-mode)${RST}" "${labels[@]}" || return 0
  MODE="${vals[$PICK_INDEX]}"; save_cfg
}

# Sub-picker: choose the model (maps to claude --model).
choose_model() {
  local -a labels=(
    "default   ${DIM}whatever your claude config uses${RST}"
    "opus      ${DIM}most capable${RST}"
    "sonnet    ${DIM}balanced${RST}"
    "haiku     ${DIM}fastest / cheapest${RST}"
  )
  local -a vals=(default opus sonnet haiku)
  pick_one "${BOLD}${C3} MODEL ${RST} ${GRY}(claude --model)${RST}" "${labels[@]}" || return 0
  MODEL="${vals[$PICK_INDEX]}"; save_cfg
}

launch_label() {
  if [ "$LAUNCH" = "detached" ]; then printf '%sdetached%s %s(backend / connect from app)%s' "$C2" "$RST" "$DIM" "$RST"
  else printf '%sattach%s %s(open here over ssh)%s' "$GRN" "$RST" "$DIM" "$RST"; fi
}

# Settings screen, Claude-style arrow menu. Mirrors the real claude launch flags.
options_screen() {
  while :; do
    local -a rows=(
      "launch mode       → $(launch_label)"
      "permission mode   → $(mode_label)   ${DIM}--permission-mode${RST}"
      "model             → $(model_label)   ${DIM}--model${RST}"
      "remote control    → $(rc_label)   ${DIM}--remote-control${RST}"
      "continue last     → $(continue_label)   ${DIM}--continue${RST}"
      "${GRY}back to menu${RST}"
    )
    render_extra() { render_options_footer; }
    pick_one "${BOLD}${C3} OPTIONS ${RST} ${GRY}apply to NEW sessions${RST}" "${rows[@]}"
    local rc=$?
    unset -f render_extra
    [ "$rc" -ne 0 ] && return 0           # cancelled -> back
    case "$PICK_INDEX" in
      0) [ "$LAUNCH" = "detached" ] && LAUNCH=attach || LAUNCH=detached; save_cfg ;;
      1) choose_mode ;;
      2) choose_model ;;
      3) [ "$RC" = "on" ] && RC=off || RC=on; save_cfg ;;
      4) [ "$CONTINUE" = "on" ] && CONTINUE=off || CONTINUE=on; save_cfg ;;
      5) return 0 ;;
    esac
  done
}

# Echo the dirs of currently-live claude-* tmux sessions, one per line.
# List ctc-managed sessions as "dir|state". state is "live" if a claude process
# is actually running in the session, or "idle" if only a shell is left (claude
# exited but the tmux session lingers) — a bare has-session check can't tell
# those apart, and a crashed backend shouldn't read as healthy.
list_live() {
  local name path cmds
  while IFS='|' read -r name path; do
    case "$name" in claude-*) ;; *) continue ;; esac
    [ -n "$path" ] || continue
    # commands running across all panes of this session
    cmds="$("$TMUX_BIN" list-panes -t "$name" -F '#{pane_current_command}' 2>/dev/null)"
    if printf '%s\n' "$cmds" | grep -qiE 'claude|node'; then
      printf '%s|live\n' "$path"
    else
      printf '%s|idle\n' "$path"
    fi
  done < <("$TMUX_BIN" list-sessions -F '#{session_name}|#{session_path}' 2>/dev/null)
}

# Per-session actions when you select a RUNNING session: attach here, or kill.
running_session_actions() {
  local dir="$1" sess; sess="$(session_name "$dir")"
  local -a rows=(
    "$(printf '%s[a]%s attach here %s(ssh/tmux)%s' "$GRN" "$RST" "$DIM" "$RST")"
    "$(printf '%s[k]%s kill this session' "$RED" "$RST")"
    "$(printf '%s[b]%s back' "$GRY" "$RST")"
  )
  PICK_KEYS="a:0 k:1 b:2" \
    pick_one "$(printf '%s%s%s  %s%s%s' "$BOLD" "$(basename "$dir")" "$RST" "$GRY" "$sess" "$RST")" "${rows[@]}" \
    || return 0
  case "$PICK_INDEX" in
    0) LAUNCH=attach launch "$dir" ;;                 # attach via tmux (exec)
    1) "$TMUX_BIN" kill-session -t "$sess" 2>/dev/null \
         && { printf '\n %s✗ killed%s %s\n' "$RED" "$RST" "$sess"; sleep 1; } ;;
    2) return 0 ;;
  esac
}

# Sub-screen: pick a project to launch a NEW (detached) backend session.
launch_new_screen() {
  local -a opts=() rows=() seen=" "
  local h r name
  # recent (history) first, then every repo under BASE
  if [ -f "$HISTFILE" ]; then
    while IFS= read -r h; do
      [ -d "$h" ] || continue
      case "$seen" in *" $h "*) ;; *) opts+=("$h"); seen+="$h ";; esac
    done < "$HISTFILE"
  fi
  local hist_end=${#opts[@]}
  while IFS= read -r r; do
    case "$seen" in *" $r "*) ;; *) opts+=("$r"); seen+="$r ";; esac
  done < <(list_repos)

  local i=0
  for o in "${opts[@]}"; do
    name="$(basename "$o")"
    if [ "$i" -lt "$hist_end" ]; then rows+=("$(printf '%s◷%s %s' "$YEL" "$RST" "$name")")
    else rows+=("$(printf '%s·%s %s%s%s' "$GRY" "$RST" "$DIM" "$name" "$RST")"); fi
    i=$((i+1))
  done
  rows+=("${C3}┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄${RST}")
  rows+=("$(printf '%s[/]%s type / paste a path' "$ORG" "$RST")")
  local IDX_DIV=$((${#opts[@]})) IDX_PATH=$(( ${#opts[@]} + 1 ))

  PICK_SKIP=$IDX_DIV PICK_KEYS="/:$IDX_PATH" \
    pick_one "${DIM}launch new — pick a project${RST}" "${rows[@]}" || return 0
  case "$PICK_INDEX" in
    "$IDX_PATH")
      printf ' %spath:%s ' "$ORG" "$RST"; local p; read -r p
      [ -n "$p" ] || return 0
      launch "$p" ;;
    *) launch "${opts[$PICK_INDEX]}" ;;
  esac
}

# Top-level session manager.
menu() {
  local -a live=() states=() rows=()
  local d st; while IFS='|' read -r d st; do
    [ -n "$d" ] && { live+=("$d"); states+=("${st:-live}"); }
  done < <(list_live)
  local nlive=${#live[@]}

  local i
  for i in "${!live[@]}"; do
    d="${live[i]}"
    if [ "${states[i]}" = "idle" ]; then
      rows+=("$(printf '%s◌%s %-20s %sidle · claude exited%s' "$GRY" "$RST" "$(basename "$d")" "$DIM" "$RST")")
    else
      rows+=("$(printf '%s●%s %-20s %slive · connect from app%s' "$GRN" "$RST" "$(basename "$d")" "$DIM" "$RST")")
    fi
  done
  rows+=("${C3}┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄${RST}")
  rows+=("$(printf '%s[n]%s launch new session…' "$C1" "$RST")")
  rows+=("$(printf '%s[o]%s options' "$ORG" "$RST")")
  local IDX_DIV=$nlive IDX_NEW=$((nlive+1)) IDX_OPT=$((nlive+2))
  local IDX_KILL=-1 IDX_QUIT
  if [ "$nlive" -gt 1 ]; then
    rows+=("$(printf '%s[k]%s kill sessions… %s(multi)%s' "$RED" "$RST" "$DIM" "$RST")")
    IDX_KILL=$((nlive+3)); IDX_QUIT=$((nlive+4))
  else
    IDX_QUIT=$((nlive+3))
  fi
  rows+=("$(printf '%s[q]%s quit' "$GRY" "$RST")")

  local title
  if [ "$nlive" -gt 0 ]; then
    title="$(printf '%s%d running%s %s· select to manage%s' "$GRN" "$nlive" "$RST" "$DIM" "$RST")"
  else
    title="$(printf '%sno running sessions · launch one below%s' "$DIM" "$RST")"
  fi
  local hk="n:$IDX_NEW o:$IDX_OPT"
  [ "$IDX_KILL" -ge 0 ] && hk="$hk k:$IDX_KILL"
  PICK_SKIP=$IDX_DIV PICK_KEYS="$hk" PICK_SHIFTTAB=cycle_mode pick_one "$title" "${rows[@]}"
  [ "$?" -ne 0 ] && { printf '%s  later.%s\n' "$GRY" "$RST"; exit 0; }

  case "$PICK_INDEX" in
    "$IDX_NEW")  launch_new_screen; menu ;;
    "$IDX_OPT")  options_screen; menu ;;
    "$IDX_KILL") kill_screen "$nlive" "${live[@]}"; menu ;;
    "$IDX_QUIT") printf '%s  later.%s\n' "$GRY" "$RST"; exit 0 ;;
    *) running_session_actions "${live[$PICK_INDEX]}"; menu ;;   # a running session
  esac
}

# Multi-select kill screen. $1 = live_count, rest = live dirs (opts[0..live-1]).
kill_screen() {
  local live_count="$1"; shift
  local -a live=("$@")
  if [ "$live_count" -eq 0 ] || [ "${#live[@]}" -eq 0 ]; then
    banner; printf '\n %sno live sessions to kill%s\n' "$YEL" "$RST"; sleep 1; return 0
  fi
  local -a rows=() d
  for d in "${live[@]}"; do
    rows+=("$(printf '%s  %s(%s)%s' "$(basename "$d")" "$GRY" "$d" "$RST")")
  done
  pick_many "${BOLD}${RED} KILL SESSIONS ${RST}  ${GRY}Space to mark, Enter to kill${RST}" "${rows[@]}" \
    || return 0
  # collect marked
  local -a victims=(); local i
  for ((i=0;i<${#live[@]};i++)); do [ "${PICK_MARKS[i]}" = "1" ] && victims+=("${live[i]}"); done
  [ "${#victims[@]}" -eq 0 ] && { printf '\n %snothing marked%s\n' "$GRY" "$RST"; sleep 1; return 0; }
  printf '\n %skill %d session(s)?%s [y/N]: ' "$RED" "${#victims[@]}" "$RST"
  local yn; read -r yn
  case "$yn" in
    y|Y)
      for d in "${victims[@]}"; do
        local sess; sess="$(session_name "$d")"
        "$TMUX_BIN" kill-session -t "$sess" 2>/dev/null \
          && printf ' %s✗ killed%s %s\n' "$RED" "$RST" "$sess" \
          || printf ' %scould not kill%s %s\n' "$YEL" "$RST" "$sess"
      done; sleep 1 ;;
    *) printf ' %skept%s\n' "$GRY" "$RST"; sleep 1 ;;
  esac
  return 0
}

main() {
  command -v "$CLAUDE_BIN" >/dev/null 2>&1 || command -v claude >/dev/null 2>&1 \
    || die "claude not found on PATH. Install Claude Code: https://code.claude.com"
  command -v "$TMUX_BIN" >/dev/null 2>&1 || command -v tmux >/dev/null 2>&1 \
    || die "tmux not found on PATH. Install it (e.g. apt install tmux / brew install tmux)."
  load_cfg
  resolve_base
  if [ "$#" -eq 0 ]; then
    menu
  else
    local target
    if target="$(resolve_arg "$1")"; then
      launch "$target"   # returns here (detached, or after detaching from attach)
      menu               # then drop into the session manager
    else
      printf '%sNo single match for "%s" — pick from the list:%s\n' "$YEL" "$1" "$RST"
      menu
    fi
  fi
}

main "$@"
